# ═══════════════════════════════════════════════════════════════
# CEO RENTABLE OS™ — VARIABLES DE ENTORNO
# ═══════════════════════════════════════════════════════════════

# 📋 INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env.local
# 2. Reemplaza los valores con tus claves reales
# 3. NUNCA hagas commit de .env.local
# 4. Solo VITE_* variables son públicas (visibles en frontend)

# ═══════════════════════════════════════════════════════════════
# 🔵 SUPABASE (BASES DE DATOS + AUTENTICACIÓN)
# ═══════════════════════════════════════════════════════════════

# URL de tu proyecto Supabase
# Obtener en: https://supabase.com/dashboard/project/[PROJECT_ID]/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon Key (para el frontend - limitada por RLS)
# Obtener en: https://supabase.com/dashboard/project/[PROJECT_ID]/settings/api
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (SOLO para backend - máximos permisos)
# ⚠️ NUNCA expongas esto en el frontend
# Obtener en: https://supabase.com/dashboard/project/[PROJECT_ID]/settings/api
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ═══════════════════════════════════════════════════════════════
# 💳 STRIPE (PAGOS)
# ═══════════════════════════════════════════════════════════════

# Stripe Public Key (para el fronted - permite crear sesiones de pago)
# Obtener en: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxx

# Stripe Secret Key (SOLO para backend - acceso total)
# ⚠️ NUNCA expongas esto en el frontend
# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxx

# Webhook Secret (para validar webhooks de Stripe)
# Obtener en: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx


# ═══════════════════════════════════════════════════════════════
# 📧 RESEND (CORREOS)
# ═══════════════════════════════════════════════════════════════

# API Key de Resend (SOLO servidor, no frontend)
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# Email "from" para los correos transaccionales
# Ejemplo: noreply@tudominio.com
RESEND_FROM_EMAIL=noreply@ceorentable.com

# Email del soporte para respuestas
RESEND_REPLY_TO=soporte@ceorentable.com

# Endpoint interno para envío (frontend -> backend)
# En local/prod deja este valor por defecto si expones el endpoint en la misma app
VITE_EMAIL_API_ENDPOINT=/api/send-email


# ═══════════════════════════════════════════════════════════════
# 🤖 GOOGLE GEMINI API (IA)
# ═══════════════════════════════════════════════════════════════

# API Key de Google Gemini
# Obtener en: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxx


# ═══════════════════════════════════════════════════════════════
# 🌐 URLS Y CONFIGURACIÓN
# ═══════════════════════════════════════════════════════════════

# URL de tu aplicación (para redirecciones, webhooks, etc)
VITE_APP_URL=http://localhost:5173

# En producción, cambiar a:
# VITE_APP_URL=https://tudominio.com


# ═══════════════════════════════════════════════════════════════
# 📊 CONFIGURACIÓN DE APLICACIÓN
# ═══════════════════════════════════════════════════════════════

# Moneda por defecto
VITE_DEFAULT_CURRENCY=USD

# Zona horaria por defecto
VITE_DEFAULT_TIMEZONE=America/Mexico_City

# Emails admin de respaldo en frontend (separados por coma)
# Usar solo para compatibilidad legacy mientras migras roles en DB
VITE_ADMIN_EMAILS=ceorentable@gmail.com

# Modo de depuración
VITE_DEBUG_MODE=false


# ═══════════════════════════════════════════════════════════════
# 💰 PLANES DE SUSCRIPCIÓN (Stripe Product IDs)
# ═══════════════════════════════════════════════════════════════

# Plan Básico: $27/mes
VITE_STRIPE_PLAN_BASICO_ID=price_xxxxxxxxxxxxxxxxxxxxxx

# Plan Pro: $47/mes
VITE_STRIPE_PLAN_PRO_ID=price_xxxxxxxxxxxxxxxxxxxxxx


# ═══════════════════════════════════════════════════════════════
# 🔗 INTEGRACIONES EXTERNAS
# ═══════════════════════════════════════════════════════════════

# Si necesitas más integraciones:
# - WhatsApp Business API
# - Google Workspace
# - Zapier
# Añádelas aquí con VITE_ prefix si son públicas
# o sin prefijo si son solo backend


# ═══════════════════════════════════════════════════════════════
# ⚠️ CHECKLIST DE SEGURIDAD
# ═══════════════════════════════════════════════════════════════

# ✅ Verificar que .env.local está en .gitignore
# ✅ NUNCA hacer push de .env.local a Git
# ✅ En Vercel/producción usar Variables de Entorno en Dashboard
# ✅ Rotar claves regularmente
# ✅ Usar diferentes claves para dev/staging/production
# ✅ Las claves SECRET_KEY solo en backend (.env, no .env.local)
